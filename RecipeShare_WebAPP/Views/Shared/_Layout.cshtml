<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RecipeShare_WebAPP</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RecipeShare_WebAPP.styles.css" asp-append-version="true" />
</head>
<body>

    <div class="site-logo">
        <img src="~/images/logo.png" alt="Logo" />
        
    </div>
    <header>
       
        <nav class="navbar navbar-expand-lg custom-navbar fixed-top">
            <div class="container">

                <a class="navbar-brand site-title" asp-controller="Home" asp-action="Index">
                    Recipe Share
                </a>
                <button class="navbar-toggler custom-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav mx-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link custom-nav-link" asp-controller="Home" asp-action="Index">Начало</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link custom-nav-link" asp-controller="Recipes" asp-action="Index">Рецепти</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link custom-nav-link" asp-controller="Recipes" asp-action="Create">Добави рецепта</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - RecipeShare 
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
