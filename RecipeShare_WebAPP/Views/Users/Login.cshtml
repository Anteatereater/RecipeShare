@using RecipeShare_WebAPP.Models.Users
@model LoginViewModel

@{
    ViewData["Title"] = "Вход";
}

<div class="auth-page d-flex align-items-center justify-content-center">
    <div class="auth-card shadow-lg p-4 rounded-4">
        <div class="text-center mb-4">
            <h2 class="fw-bold">Добре дошъл</h2>
            <p class="text-muted">Влез в своя акаунт</p>
        </div>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                <label asp-for="Email">Имейл</label>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Password" class="form-control" placeholder="Парола" />
                <label asp-for="Password">Парола</label>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="RememberMe" />
                <label class="form-check-label" asp-for="RememberMe">
                    Запомни ме
                </label>
            </div>

            <button type="submit" class="btn btn-warning w-100 py-2 fw-semibold rounded-3">
                Вход
            </button>

            <div class="text-center mt-3">
                <span class="text-muted">Нямаш акаунт?</span>
                <a asp-controller="Users" asp-action="Register" class="text-decoration-none fw-semibold">
                    Регистрация
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
