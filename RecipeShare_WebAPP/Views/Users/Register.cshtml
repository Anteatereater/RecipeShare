@using RecipeShare_WebAPP.Models.Users
@model RegisterViewModel

@{
    ViewData["Title"] = "Регистрация";
}

<div class="auth-page d-flex align-items-center justify-content-center">
    <div class="auth-card shadow-lg p-4 rounded-4">
        <div class="text-center mb-4">
            <h2 class="fw-bold">Създай профил</h2>
            <p class="text-muted">Присъедини се към Recipe Share</p>
        </div>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                <label asp-for="Email">Имейл</label>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Password" class="form-control" placeholder="Парола" />
                <label asp-for="Password">Парола</label>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Потвърди парола" />
                <label asp-for="ConfirmPassword">Потвърди парола</label>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-warning w-100 py-2 fw-semibold rounded-3">
                Регистрация
            </button>

            <div class="text-center mt-3">
                <span class="text-muted">Вече имаш акаунт?</span>
                <a asp-controller="Users" asp-action="Login" class="text-decoration-none fw-semibold">Вход</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}