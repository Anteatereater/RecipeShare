@using RecipeShare.Web.ViewModels.ViewModels.Recipes
@model RecipeIndexViewModel

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold display-6">Рецепти с <span class="text-warning">"@ViewData["SearchTerm"]"</span></h2>
        <p class="text-muted">Открий нови идеи с любимите си продукти</p>
    </div>

    <div class="row g-4">
        @foreach (var recipe in Model.Recipes)
        {
            <div class="col-lg-6 col-12">
                <div class="card h-100 shadow border-0 rounded-4 overflow-hidden recipe-card">
                    <div class="row g-0 h-100">
                        <div class="col-md-5">
                            <img src="@(string.IsNullOrEmpty(recipe.ImageUrl) ? "/images/no-image.jpg" : recipe.ImageUrl)"
                                 class="img-fluid h-100 w-100"
                                 style="object-fit: cover; min-height: 250px;" alt="@recipe.Name">
                        </div>

                        <div class="col-md-7 d-flex flex-column">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-3">@recipe.CategoryName</span>
                                    <small class="text-muted"><i class="bi bi-bar-chart"></i> @recipe.Difficulty</small>
                                </div>

                                <h4 class="card-title fw-bold mb-3">@recipe.Name</h4>

                                <p class="text-muted small mb-3 text-truncate-2">@recipe.Description</p>

                                <div class="ingredients-preview mb-3">
                                    <p class="small fw-bold text-uppercase text-muted mb-2" style="font-size: 0.7rem;">Съставки:</p>
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var comp in recipe.Components.Take(6)) // Показваме само първите 6
                                        {
                                            <a asp-action="ByComponent" asp-route-id="@comp.Id"
                                               class="badge rounded-pill bg-light text-dark text-decoration-none border p-2 ingredient-tag">
                                                @comp.Name
                                            </a>
                                        }
                                        @if (recipe.Components.Count > 6)
                                        {
                                            <span class="badge rounded-pill bg-light text-muted border p-2">+ още</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="card-footer bg-transparent border-0 p-4 pt-0 mt-auto">
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">От <strong>@recipe.AuthorName</strong></small>
                                    <a asp-action="Details" asp-route-id="@recipe.Id" class="btn btn-warning fw-bold px-4 rounded-pill">Детайли</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .recipe-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .recipe-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .ingredient-tag:hover {
        background-color: #ff9800 !important;
        color: white !important;
        border-color: #ff9800 !important;
    }

    .bg-warning-subtle {
        background-color: #fff3e0;
    }
</style>