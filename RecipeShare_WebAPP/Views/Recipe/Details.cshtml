@using RecipeShare.Web.ViewModels.ViewModels.Recipes
@model RecipeDetailsViewModel

@{
    ViewData["Title"] = "Детайли";
}

<div class="container py-5">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="row g-0">
            <div class="col-lg-6">
                <img src="@(Model.ImageUrls.FirstOrDefault() ?? "https://via.placeholder.com/800x500?text=No+Image")"
                     class="img-fluid w-100 h-100 object-fit-cover" alt="@Model.Name" />
            </div>

            <div class="col-lg-6">
                <div class="p-4 p-lg-5">
                    <span class="badge bg-warning text-dark mb-3">@Model.CategoryName</span>
                    <h1 class="fw-bold mb-3">@Model.Name</h1>
                    <p class="text-muted mb-4">@Model.Description</p>

                    <div class="mb-3"><strong>Трудност:</strong> @Model.Difficulty</div>
                    <div class="mb-3"><strong>Време:</strong> @Model.PreparationTimeMinutes минути</div>
                    <div class="mb-3"><strong>Автор:</strong> @Model.AuthorName</div>
                    <div class="mb-4"><strong>Създадена:</strong> @Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>

                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-action="Index" class="btn btn-outline-warning rounded-3">Назад</a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning rounded-3">Редактирай</a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger rounded-3">Изтрий</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>