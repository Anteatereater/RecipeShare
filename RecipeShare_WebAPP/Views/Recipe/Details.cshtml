@using System.Security.Claims
@using RecipeShare.Web.ViewModels.ViewModels.Recipes
@model RecipeDetailsViewModel

@{
    ViewData["Title"] = "Детайли";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="container py-5">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="row g-0">
            <div class="col-lg-6">
                <img src="@(Model.ImageUrls.FirstOrDefault() ?? "https://via.placeholder.com/800x500?text=No+Image")"
                     class="img-fluid w-100 h-100 object-fit-cover" alt="@Model.Name" />
            </div>

            <div class="col-lg-6">
                <div class="p-4 p-lg-5">
                    <span class="badge bg-warning text-dark mb-3">@Model.CategoryName</span>
                    <h1 class="fw-bold mb-3">@Model.Name</h1>
                    <p class="text-muted mb-4">@Model.Description</p>

                    <div class="mb-3"><strong>Трудност:</strong> @Model.Difficulty</div>
                    <div class="mb-3"><strong>Време:</strong> @Model.PreparationTimeMinutes минути</div>
                    <div class="mb-3"><strong>Автор:</strong> @Model.AuthorName</div>
                    <div class="mb-4"><strong>Създадена:</strong> @Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>

                    <div class="mt-4 d-flex gap-2 flex-wrap">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Назад
                        </a>

                        @if (User.IsInRole("Admin") || Model.UserId == currentUserId)
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                                <i class="bi bi-pencil-square"></i> Редактирай
                            </a>

                            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-danger" onclick="return confirm('Сигурни ли сте?')">
                                    <i class="bi bi-trash"></i> Изтрий
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<hr class="my-5" />

<div class="recipe-ingredients-section mb-5">
    <h4 class="fw-bold mb-4">
        <i class="bi bi-egg-fried text-warning"></i> Необходими продукти
    </h4>
    <p class="text-muted small mb-3">Кликни върху продукт, за да видиш други рецепти с него:</p>

    <div class="d-flex flex-wrap gap-2">
        @foreach (var item in Model.Components)
        {
            <a asp-controller="Recipe"
               asp-action="ByComponent"
               asp-route-id="@item.Id"
               class="btn btn-ingredient-chip shadow-sm">
                @item.Name
            </a>
        }
    </div>
</div>

<hr />
<div class="mt-4">
    <h3 class="fw-bold mb-3">Коментари</h3>

    @if (User.Identity!.IsAuthenticated)
    {
        <form asp-controller="Comment" asp-action="Add" method="post" class="mb-4">
            <input type="hidden" name="recipeId" value="@Model.Id" />
            <div class="mb-2">
                <textarea name="content" class="form-control" rows="3" placeholder="Напиши коментар..."></textarea>
            </div>
            <button type="submit" class="btn btn-warning">Публикувай</button>
        </form>
    }

    @foreach (var comment in Model.Comments)
    {
        <div class="card mb-3 shadow-sm border-warning">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <h6 class="fw-bold text-warning">@comment.AuthorName</h6>
                    <small class="text-muted">@comment.CreatedAt.ToString("g")</small>
                </div>
                <p>@comment.Text</p>

                @if (comment.UserId == currentUserId || User.IsInRole("Admin"))
                {
                    <form asp-controller="Comment" asp-action="Delete" asp-route-id="@comment.Id" method="post">
                        <button type="submit" class="btn btn-sm btn-outline-danger border-0">Изтрий</button>
                    </form>
                }
            </div>
        </div>
    }
</div>
<style>
    .btn-ingredient-chip {
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
        color: #495057;
        border-radius: 50px;
        padding: 8px 22px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s ease-in-out;
    }

        .btn-ingredient-chip:hover {
            background-color: #ff9800;
            color: white;
            border-color: #f57c00;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(255, 152, 0, 0.2) !important;
        }

    .recipe-ingredients-section h4 {
        color: #333;
        border-left: 5px solid #ff9800;
        padding-left: 15px;
    }
</style>