@using RecipeShare.Web.ViewModels.ViewModels.Recipes
@model RecipeCreateViewModel

<div class="container py-5">
    <div class="auth-card mx-auto shadow-lg p-4 rounded-4" style="max-width: 850px; background: #fff;">
        <h2 class="fw-bold mb-4 text-center">Нова рецепта</h2>

        <form asp-action="Create" method="post" id="recipe-form">
            
            <div class="row">
                <div class="col-md-12 mb-3">
                    <div class="form-floating">
                        <input asp-for="Name" class="form-control" />
                        <label asp-for="Name">Заглавие</label>
                    </div>
                </div>

                    <div class="col-md-12 mb-3">
                        <div class="form-floating">
                            <textarea asp-for="Description" class="form-control" style="height: 120px" placeholder="Описание"></textarea>
                            <label asp-for="Description">Начин на приготвяне</label>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>

                <div class="col-md-4">
                    <div class="form-floating mb-3"> 
                        <input asp-for="PreparationTimeMinutes" type="number" min="1" class="form-control" placeholder="Време" />
                        <label asp-for="PreparationTimeMinutes">Време (мин)</label>
                        <span asp-validation-for="PreparationTimeMinutes" class="text-danger small"></span>
                    </div>
                </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label small text-muted mb-1">Трудност</label>
                        <select asp-for="Difficulty" asp-items="Model.Difficulties" class="form-select"></select>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label small text-muted mb-1">Категория</label>
                        <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select"></select>
                    </div>
                

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="form-floating">
                            <input asp-for="ImageUrl" class="form-control" placeholder="URL" />
                            <label asp-for="ImageUrl">Линк към снимка</label>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="form-floating">
                            <input asp-for="ImageName" class="form-control" placeholder="Име" />
                            <label asp-for="ImageName">Име на снимката</label>
                        </div>
                    </div>
                </div>

            </div>

            <div class="mb-4">
                <h5 class="fw-bold mb-3">Избери съставки</h5>
                <select id="component-selector" class="form-select mb-3 shadow-sm">
                    <option value="">-- Кликни тук, за да добавиш съставка --</option>
                    @foreach (var comp in Model.AvailableComponents)
                    {
                        <option value="@comp.Value">@comp.Text</option>
                    }
                </select>

                <div id="selected-components-container" class="d-flex flex-wrap gap-2 p-3 border rounded-3 bg-light min-vh-10">
                    <p id="placeholder-text" class="text-muted m-0 small">Избраните продукти ще се появят тук...</p>
                </div>
            </div>

            <button type="submit" class="btn btn-warning btn-lg w-100 py-3 fw-bold rounded-3 shadow text-white">
                ЗАПАЗИ
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        if ("@(ViewData.ModelState.IsValid)" === "False") {
            Swal.fire({ title: 'Грешка!', text: 'Има грешно въведени данни!', icon: 'error', confirmButtonColor: '#ff9800' });
        }

        const selector = document.getElementById('component-selector');
        const container = document.getElementById('selected-components-container');
        const placeholder = document.getElementById('placeholder-text');
        let selectedCount = 0;

        selector.addEventListener('change', function () {
            const componentId = this.value;
            const componentName = this.options[this.selectedIndex].text;
            if (!componentId || document.querySelector(`input[value="${componentId}"]`)) { this.value = ''; return; }

            if (placeholder) placeholder.style.display = 'none';

            const chip = document.createElement('div');
            chip.className = 'btn-orange-chip d-flex align-items-center gap-2';
            chip.innerHTML = `
                <span>${componentName}</span>
                <i class="bi bi-x-circle-fill"></i>
                <input type="hidden" name="SelectedComponents[${selectedCount}].ComponentId" value="${componentId}" />
            `;

            chip.onclick = function() { this.remove(); reindex(); };
            container.appendChild(chip);
            selectedCount++;
            this.value = '';
        });

        function reindex() {
            const inputs = container.querySelectorAll('input[type="hidden"]');
            inputs.forEach((input, i) => { input.name = `SelectedComponents[${i}].ComponentId`; });
            selectedCount = inputs.length;
            if (selectedCount === 0) placeholder.style.display = 'block';
        }
    </script>
}

<style>
    
    .form-control, .form-select {
        background-color: #f8f9fa !important; 
        border: 1px solid #dee2e6; 
        transition: all 0.2s ease-in-out;
    }


        .form-control:focus, .form-select:focus {
            background-color: #ffffff !important; 
            border-color: #ff9800; 
            box-shadow: 0 0 0 0.25rem rgba(255, 152, 0, 0.25); 
        }


    textarea.form-control {
        background-color: #f8f9fa !important;
    }


    .btn-orange-chip {
        background-color: #fff3e0;
        border: 1px solid #ffb74d;
        color: #e65100;
        border-radius: 50px;
        padding: 5px 15px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-orange-chip:hover {
            background-color: #ffb74d;
            color: #fff;
        }
</style>
