@using RecipeShare.Web.ViewModels.ViewModels.Recipes
@model RecipeIndexViewModel

@{
    ViewData["Title"] = "Рецепти";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="fw-bold mb-1">Рецепти</h1>
            <p class="text-muted mb-0">Разгледай всички рецепти в Recipe Share</p>
        </div>
        <a asp-action="Create" class="btn btn-warning rounded-3">Добави рецепта</a>
    </div>

    <form method="get" class="row g-3 mb-5">
        <div class="col-md-3">
            <select name="category" class="form-select">
                <option value="">Всички категории</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category" selected="@(Model.Category == category)">@category</option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <select name="difficulty" class="form-select">
                <option value="">Филтър трудност</option>
                @foreach (var difficulty in Model.Difficulties)
                {
                    <option value="@difficulty" selected="@(Model.Difficulty == difficulty)">@difficulty</option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <select name="sortOrder" class="form-select">
                <option value="">Сортирай по...</option>
                <option value="time_asc" selected='@(Context.Request.Query["sortOrder"] == "time_asc")'>Най-бързи</option>
                <option value="time_desc" selected='@(Context.Request.Query["sortOrder"] == "time_desc")'>Най-бавни</option>
                <option value="diff_asc" selected='@(Context.Request.Query["sortOrder"] == "diff_asc")'>Лесни първо</option>
                <option value="diff_desc" selected='@(Context.Request.Query["sortOrder"] == "diff_desc")'>Трудни първо</option>
            </select>
        </div>

        <div class="col-md-3 d-grid">
            <button type="submit" class="btn btn-warning">Приложи филтрите</button>
        </div>
    </form>

        <div class="col-md-3">
            <input name="maxTime" value="@Model.MaxTime" class="form-control" placeholder="Макс. време (мин)" />
        </div>

        <div class="col-md-1 d-grid">
            <button type="submit" class="btn btn-outline-warning">Търси</button>
        </div>
    

    @if (Model.Recipes.Any())
    {
        <div class="row g-4">
            @foreach (var recipe in Model.Recipes)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="recipe-card card h-100 shadow-sm border-0 rounded-4" style="background-color: #ffcc99;">
                        <img src="@(recipe.ImageUrl ?? "https://via.placeholder.com/600x400?text=No+Image")"
                             class="card-img-top recipe-card-img" alt="@recipe.Name" style="background-color: #ffcc99;" />

                        <div class="card-body" style="background-color: #ffcc99;">
                            <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                                <span class="badge bg-warning text-dark">@recipe.CategoryName</span>
                                <small class="text-muted">@recipe.PreparationTimeMinutes мин</small>
                            </div>

                            <h5 class="card-title fw-bold" style="background-color: #ffcc99;">@recipe.Name</h5>
                            <p class="card-text text-muted" style="background-color: #ffcc99;">
                                @(recipe.Description.Length > 100 ? recipe.Description.Substring(0, 100) + "..." : recipe.Description)
                            </p>

                            <div class="recipe-meta small text-muted">
                                <div><strong>Трудност:</strong> @recipe.Difficulty</div>
                                <div><strong>Автор:</strong> @recipe.AuthorName</div>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 pb-4" style="background-color: #ffcc99;">
                            <a asp-action="Details" asp-route-id="@recipe.Id" class="btn btn-outline-warning rounded-3">
                                Виж повече
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <p class="text-muted fs-5">Няма намерени рецепти.</p>
        </div>
    }
</div>
